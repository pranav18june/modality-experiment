# Environment variables required by the Modality Experiment Platform
# Copy this file to `.env` and fill in real values before running locally.
# On Vercel, set these in: Project Settings → Environment Variables

# ── Flask ───────────────────────────────────────────────────────────────────
# A long, random secret string used to sign session cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: The app will refuse to start if this is not set.
SECRET_KEY=meowmeowmeowmeowmeowmeowmeowmeow

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# Full SRV connection string from the Atlas dashboard.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Create a free M0 cluster at: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://pranav18june_db_user:W9hq1WfkUY8BCD0w@cluster0.cer9pia.mongodb.net/?appName=Cluster0
# ── Admin panel ──────────────────────────────────────────────────────────────
# Password for the /admin route. Change this before deployment.
ADMIN_PASSWORD=research2025
